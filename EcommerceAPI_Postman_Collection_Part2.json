{
  "info": {
    "name": "E-commerce API Collection - Part 2",
    "description": "Additional endpoints for Categories, Cart, Orders, Reviews, and more",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/categories",
              "host": ["{{baseURL}}"],
              "path": ["categories"]
            },
            "description": "Get all product categories"
          }
        },
        {
          "name": "Get Category by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/categories/{{categoryId}}",
              "host": ["{{baseURL}}"],
              "path": ["categories", "{{categoryId}}"]
            },
            "description": "Get single category details"
          }
        },
        {
          "name": "Get Category Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/categories/{{categoryId}}/products?page=1&limit=10",
              "host": ["{{baseURL}}"],
              "path": ["categories", "{{categoryId}}", "products"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Get products in a specific category"
          }
        },
        {
          "name": "Create Category (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics\",\n  \"description\": \"Electronic devices and gadgets\",\n  \"image\": \"electronics.jpg\",\n  \"slug\": \"electronics\"\n}"
            },
            "url": {
              "raw": "{{baseURL}}/categories",
              "host": ["{{baseURL}}"],
              "path": ["categories"]
            },
            "description": "Create a new category (Admin only)"
          }
        },
        {
          "name": "Update Category (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics & Gadgets\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": {
              "raw": "{{baseURL}}/categories/{{categoryId}}",
              "host": ["{{baseURL}}"],
              "path": ["categories", "{{categoryId}}"]
            },
            "description": "Update category (Admin only)"
          }
        },
        {
          "name": "Delete Category (Admin)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/categories/{{categoryId}}",
              "host": ["{{baseURL}}"],
              "path": ["categories", "{{categoryId}}"]
            },
            "description": "Delete category (Admin only)"
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/cart",
              "host": ["{{baseURL}}"],
              "path": ["cart"]
            },
            "description": "Get current user's cart"
          }
        },
        {
          "name": "Add to Cart",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product\": \"{{productId}}\",\n  \"quantity\": 2,\n  \"selectedVariations\": {\n    \"color\": \"Black\",\n    \"size\": \"M\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseURL}}/cart/items",
              "host": ["{{baseURL}}"],
              "path": ["cart", "items"]
            },
            "description": "Add product to cart"
          }
        },
        {
          "name": "Update Cart Item",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 3\n}"
            },
            "url": {
              "raw": "{{baseURL}}/cart/items/{{cartItemId}}",
              "host": ["{{baseURL}}"],
              "path": ["cart", "items", "{{cartItemId}}"]
            },
            "description": "Update cart item quantity"
          }
        },
        {
          "name": "Remove from Cart",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/cart/items/{{cartItemId}}",
              "host": ["{{baseURL}}"],
              "path": ["cart", "items", "{{cartItemId}}"]
            },
            "description": "Remove item from cart"
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/cart",
              "host": ["{{baseURL}}"],
              "path": ["cart"]
            },
            "description": "Clear all items from cart"
          }
        },
        {
          "name": "Apply Coupon",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"couponCode\": \"DISCOUNT10\"\n}"
            },
            "url": {
              "raw": "{{baseURL}}/cart/coupon",
              "host": ["{{baseURL}}"],
              "path": ["cart", "coupon"]
            },
            "description": "Apply coupon to cart"
          }
        },
        {
          "name": "Remove Coupon",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/cart/coupon",
              "host": ["{{baseURL}}"],
              "path": ["cart", "coupon"]
            },
            "description": "Remove coupon from cart"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Get User Orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/orders?page=1&limit=10&status=pending",
              "host": ["{{baseURL}}"],
              "path": ["orders"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "status",
                  "value": "pending",
                  "disabled": true
                }
              ]
            },
            "description": "Get user's orders with optional filtering"
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/orders/{{orderId}}",
              "host": ["{{baseURL}}"],
              "path": ["orders", "{{orderId}}"]
            },
            "description": "Get specific order details"
          }
        },
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shippingAddress\": \"{{addressId}}\",\n  \"paymentMethod\": \"card\",\n  \"paymentDetails\": {\n    \"cardNumber\": \"4111111111111111\",\n    \"expiryMonth\": \"12\",\n    \"expiryYear\": \"2025\",\n    \"cvv\": \"123\"\n  },\n  \"notes\": \"Please deliver in the evening\"\n}"
            },
            "url": {
              "raw": "{{baseURL}}/orders",
              "host": ["{{baseURL}}"],
              "path": ["orders"]
            },
            "description": "Create new order from cart"
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Changed mind\"\n}"
            },
            "url": {
              "raw": "{{baseURL}}/orders/{{orderId}}/cancel",
              "host": ["{{baseURL}}"],
              "path": ["orders", "{{orderId}}", "cancel"]
            },
            "description": "Cancel an order"
          }
        },
        {
          "name": "Get All Orders (Admin)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/orders/admin/all?page=1&limit=20&status=pending",
              "host": ["{{baseURL}}"],
              "path": ["orders", "admin", "all"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "status",
                  "value": "pending",
                  "disabled": true
                }
              ]
            },
            "description": "Get all orders for admin"
          }
        },
        {
          "name": "Update Order Status (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"shipped\",\n  \"trackingNumber\": \"TN123456789\",\n  \"notes\": \"Order shipped via FedEx\"\n}"
            },
            "url": {
              "raw": "{{baseURL}}/orders/{{orderId}}/status",
              "host": ["{{baseURL}}"],
              "path": ["orders", "{{orderId}}", "status"]
            },
            "description": "Update order status (Admin only)"
          }
        }
      ]
    }
  ]
}