{
  "info": {
    "name": "E-commerce API Collection - Part 3",
    "description": "Addresses, Wishlist, Reviews, Notifications, and Upload endpoints",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Addresses",
      "item": [
        {
          "name": "Get User Addresses",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/addresses",
              "host": ["{{baseURL}}"],
              "path": ["addresses"]
            },
            "description": "Get all user addresses"
          }
        },
        {
          "name": "Get Address by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/addresses/{{addressId}}",
              "host": ["{{baseURL}}"],
              "path": ["addresses", "{{addressId}}"]
            },
            "description": "Get specific address details"
          }
        },
        {
          "name": "Create Address",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"home\",\n  \"fullName\": \"John Doe\",\n  \"phone\": \"+1234567890\",\n  \"addressLine1\": \"123 Main Street\",\n  \"addressLine2\": \"Apt 4B\",\n  \"city\": \"New York\",\n  \"state\": \"NY\",\n  \"postalCode\": \"10001\",\n  \"country\": \"USA\",\n  \"isDefault\": true\n}"
            },
            "url": {
              "raw": "{{baseURL}}/addresses",
              "host": ["{{baseURL}}"],
              "path": ["addresses"]
            },
            "description": "Create a new address"
          }
        },
        {
          "name": "Update Address",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Doe Updated\",\n  \"phone\": \"+1234567891\",\n  \"addressLine1\": \"456 Updated Street\"\n}"
            },
            "url": {
              "raw": "{{baseURL}}/addresses/{{addressId}}",
              "host": ["{{baseURL}}"],
              "path": ["addresses", "{{addressId}}"]
            },
            "description": "Update an existing address"
          }
        },
        {
          "name": "Delete Address",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/addresses/{{addressId}}",
              "host": ["{{baseURL}}"],
              "path": ["addresses", "{{addressId}}"]
            },
            "description": "Delete an address"
          }
        },
        {
          "name": "Set Default Address",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/addresses/{{addressId}}/default",
              "host": ["{{baseURL}}"],
              "path": ["addresses", "{{addressId}}", "default"]
            },
            "description": "Set address as default"
          }
        }
      ]
    },
    {
      "name": "Wishlist",
      "item": [
        {
          "name": "Get Wishlist",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/wishlist",
              "host": ["{{baseURL}}"],
              "path": ["wishlist"]
            },
            "description": "Get user's wishlist"
          }
        },
        {
          "name": "Add to Wishlist",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product\": \"{{productId}}\"\n}"
            },
            "url": {
              "raw": "{{baseURL}}/wishlist/items",
              "host": ["{{baseURL}}"],
              "path": ["wishlist", "items"]
            },
            "description": "Add product to wishlist"
          }
        },
        {
          "name": "Remove from Wishlist",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/wishlist/items/{{productId}}",
              "host": ["{{baseURL}}"],
              "path": ["wishlist", "items", "{{productId}}"]
            },
            "description": "Remove product from wishlist"
          }
        },
        {
          "name": "Clear Wishlist",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/wishlist",
              "host": ["{{baseURL}}"],
              "path": ["wishlist"]
            },
            "description": "Clear all items from wishlist"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Get Product Reviews",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/reviews?product={{productId}}&page=1&limit=10&rating=5",
              "host": ["{{baseURL}}"],
              "path": ["reviews"],
              "query": [
                {
                  "key": "product",
                  "value": "{{productId}}"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "rating",
                  "value": "5",
                  "disabled": true
                }
              ]
            },
            "description": "Get reviews for a product"
          }
        },
        {
          "name": "Get Review by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/reviews/{{reviewId}}",
              "host": ["{{baseURL}}"],
              "path": ["reviews", "{{reviewId}}"]
            },
            "description": "Get specific review details"
          }
        },
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product\": \"{{productId}}\",\n  \"rating\": 5,\n  \"title\": \"Excellent product!\",\n  \"comment\": \"Really happy with this purchase. Great quality and fast delivery.\",\n  \"pros\": [\"Good quality\", \"Fast delivery\"],\n  \"cons\": [\"A bit expensive\"]\n}"
            },
            "url": {
              "raw": "{{baseURL}}/reviews",
              "host": ["{{baseURL}}"],
              "path": ["reviews"]
            },
            "description": "Create a new review"
          }
        },
        {
          "name": "Update Review",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 4,\n  \"title\": \"Good product - Updated\",\n  \"comment\": \"Updated my review after using for a month.\"\n}"
            },
            "url": {
              "raw": "{{baseURL}}/reviews/{{reviewId}}",
              "host": ["{{baseURL}}"],
              "path": ["reviews", "{{reviewId}}"]
            },
            "description": "Update user's own review"
          }
        },
        {
          "name": "Delete Review",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/reviews/{{reviewId}}",
              "host": ["{{baseURL}}"],
              "path": ["reviews", "{{reviewId}}"]
            },
            "description": "Delete user's own review"
          }
        },
        {
          "name": "Vote on Review",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"voteType\": \"helpful\"\n}"
            },
            "url": {
              "raw": "{{baseURL}}/reviews/{{reviewId}}/vote",
              "host": ["{{baseURL}}"],
              "path": ["reviews", "{{reviewId}}", "vote"]
            },
            "description": "Vote on review (helpful/not helpful)"
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Get Notifications",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/notifications?page=1&limit=10&type=order",
              "host": ["{{baseURL}}"],
              "path": ["notifications"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "type",
                  "value": "order",
                  "disabled": true
                }
              ]
            },
            "description": "Get user notifications with pagination"
          }
        },
        {
          "name": "Get Unread Count",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/notifications/unread-count",
              "host": ["{{baseURL}}"],
              "path": ["notifications", "unread-count"]
            },
            "description": "Get count of unread notifications"
          }
        },
        {
          "name": "Mark as Read",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notificationIds\": [\"{{notificationId1}}\", \"{{notificationId2}}\"]\n}"
            },
            "url": {
              "raw": "{{baseURL}}/notifications/read",
              "host": ["{{baseURL}}"],
              "path": ["notifications", "read"]
            },
            "description": "Mark specific notifications as read"
          }
        },
        {
          "name": "Mark All as Read",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/notifications/read-all",
              "host": ["{{baseURL}}"],
              "path": ["notifications", "read-all"]
            },
            "description": "Mark all notifications as read"
          }
        },
        {
          "name": "Delete Notification",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/notifications/{{notificationId}}",
              "host": ["{{baseURL}}"],
              "path": ["notifications", "{{notificationId}}"]
            },
            "description": "Delete a notification"
          }
        }
      ]
    },
    {
      "name": "Upload",
      "item": [
        {
          "name": "Upload Single Image",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseURL}}/upload/image",
              "host": ["{{baseURL}}"],
              "path": ["upload", "image"]
            },
            "description": "Upload a single image"
          }
        },
        {
          "name": "Upload Multiple Images",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "images",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "images",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseURL}}/upload/images",
              "host": ["{{baseURL}}"],
              "path": ["upload", "images"]
            },
            "description": "Upload multiple images (max 5)"
          }
        },
        {
          "name": "Delete Image (Admin)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/upload/image/{{filename}}",
              "host": ["{{baseURL}}"],
              "path": ["upload", "image", "{{filename}}"]
            },
            "description": "Delete an uploaded image (Admin only)"
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Server Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["health"]
            },
            "description": "Check if server is running"
          }
        }
      ]
    }
  ]
}